import java.sql.*; 

public class PruebaConexion {
    public static void main(String[] args) {
        
        String url = "jdbc:mysql://localhost:3306/biblioteca_db";
        String user = "root";
        String pass = "12345678"; 

        try {
            Connection con = DriverManager.getConnection(url, user, pass);

            // Definir la Subconsulta
            // Se busca el libro más caro
            String sql = "SELECT * FROM libros WHERE precio_alquiler = (SELECT MAX(precio_alquiler) FROM libros)";

            PreparedStatement pstmt = con.prepareStatement(sql);
            ResultSet rs = pstmt.executeQuery();

            // rs.getDouble()
            // rs.getInt()

            while (rs.next()) {
                System.out.println("El libro más caro es: " + rs.getString("titulo"));
            }
            // se puede optar por la opción de:
            while (rs.next()) {
                String nombreAlumno = rs.getString("titulo"); 
                System.out.println("El libro más caro es: " + nombreAlumno);
            }

        } catch (SQLException e) {
            e.printStackTrace();
        }
    }
}


